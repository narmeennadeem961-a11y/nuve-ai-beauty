# ─── Nuve Backend – Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# Port the server listens on (default: 3001)
PORT=3001

# Allowed frontend origin(s) – comma-separated for multiple
# Examples:
#   Local dev  → http://localhost:5500,http://127.0.0.1:5500
#   Production → https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Environment: development | production
NODE_ENV=development
